rules_version = '2';

// Firebase Storage rules for "Not a Flinch".
//
// NOTE: These rules are intentionally permissive to get the public Wall of
// Flinchers working without authentication. Tighten them for production
// (e.g. require auth, add per-file size limits, validate content-type, throttle
// writes). The single hard limit here is a 10 MiB cap per upload so a runaway
// client can't fill the bucket.
service firebase.storage {
  match /b/{bucket}/o {
    // Public Wall of Flinchers uploads. Anyone can read posted photos, anyone
    // can upload a new one. Updates / deletes are blocked from clients.
    match /wallOfFlinchers/{fileName} {
      allow read: if true;
      allow create: if request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow update, delete: if false;
    }

    // Lock everything else down by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
